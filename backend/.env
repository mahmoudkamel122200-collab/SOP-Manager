# Factory Management System - Backend Environment
# Copy to .env and fill in your actual values.

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.rquswtjcmgefdndluxxt:MahmoudKamel1%40@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DB_ECHO=false

# ─── JWT ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_strong_random_secret_min_32_chars
REFRESH_SECRET_KEY=replace_with_different_strong_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Argon2 ─────────────────────────────────────────────────────────────────
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

# ─── File Upload ────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads/documents
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=["pdf","docx","xlsx","pptx","txt"]

# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME=Factory Management System
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
TRUSTED_HOSTS=["*"]

# ─── Supabase Storage ───────────────────────────────────────────────────────
STORAGE_BACKEND=supabase
